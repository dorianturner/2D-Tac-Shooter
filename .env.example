# Local development normally needs no env file.
# Vite uses http://localhost:8787/api and ws://localhost:8787 in dev.
#
# Production on Oracle is same-origin from the Node server:
#   http://193.123.190.8/      -> apps/client/dist
#   http://193.123.190.8/api   -> Node server
#   ws://193.123.190.8/ws      -> Node WebSocket server
#
# Optional overrides:
VITE_API_BASE_URL=http://193.123.190.8/api
VITE_WS_URL=ws://193.123.190.8/ws
VITE_SERVER_PORT=8787
